PORT=3000
API_URL=http://localhost:3000

# MySQL Database
# NOTE: Docker Compose overrides MYSQL_HOST to `db` internally.
# Local dev (non-Docker) should use `localhost` (or `127.0.0.1`).
# Docker MySQL is mapped to host port 3307 to avoid conflicts.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=dragonball_api
# Set to 'true' to auto-sync entities (dev only — drops data on schema change)
MYSQL_SYNCHRONIZE=false

# JWT Secret (generate a strong random key for production)
JWT_SECRET=change-me-to-a-random-secret

# Image upload driver (local | cloudinary)
# local  — saves to /images (no config needed)
# cloudinary — requires CLOUDINARY_* vars below
UPLOAD_DRIVER=local

# Cloudinary (required when UPLOAD_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
